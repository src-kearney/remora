MLIR_DIR=/path/to/llvm-build/lib/cmake/mlir
STABLEHLO_ROOT=/path/to/stablehlo
STABLEHLO_BUILD=/path/to/stablehlo/build
# Path to an LLVM build with NVPTX backends (needed for --emit-ptx).
# If omitted, defaults to the same llvm-build used for MLIR_DIR.
LLVM_NVPTX_LIB_DIR=/path/to/llvm-project/build/lib